# -----------------------------
# Data Engineering Git Ignore
# -----------------------------

# Raw data and large files
data/
*.csv
*.csv.gz
*.parquet
*.duckdb
duckdb.db

# dbt build artifacts
/target/
/dbt_packages/

# Logs and pipeline runs
logs/
logs/*.log
logs/runs

# Python caches and virtual environments
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Service account keys and credentials
*.key
*.pem
*.crt
*.env
*.secrets
*.json
secrets/
service-account.json
*-creds.json

# Docker and Terraform artifacts
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
*.tfvars.json
terraform.rc
.terraformrc

# OS / Editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak

# Backup folders
*_backup/

# Installer / build artifacts
build/
dist/
downloads/
.eggs/
wheels/
share/python-wheels/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage*
.pytest_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# IDE / Editor settings
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject

# Misc
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
